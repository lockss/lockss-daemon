{

  publisher <
    name = Ubiquity Press
  >

  provider = Ubiquity Press
  implicit < pluginSuffix ; status ; year ; volume ; name ; param[year] >
  pluginPrefix = org.lockss.plugin.
  attr[start_stem] = index.php/

  {

    title <
      name = International Journal of Driving Science ;
      eissn = 2397-1959
    >

    comment[publisher] = Ubiquity Press
    param[base_url] = https://account.up-j-ijds.ubiquityjournal.website/
    param[journal_id] = up-j-ijds
    #LXPUB-876

    au < ojs3.ClockssOjs3Plugin ; released ; 2018 ; 1 ; International Journal of Driving Science Volume 2018 ; 2018 >
    au < ojs3.ClockssOjs3Plugin ; released ; 2021 ; 2 ; International Journal of Driving Science Volume 2021 ; 2021 >

  }

  {

      title <
        name = Journal of Open Public Health Data ;
        eissn = 2053-2407 
      >

      comment[publisher] = Ubiquity Press
      param[base_url] = http://openhealthdata.metajnl.com/
      param[journal_id] = jophd
      #LXQUEUE-2158
      
      au < ojs2.ClockssOJS2Plugin ; manifest ; 2013 ; 1 ; Journal of Open Public Health Data Volume 1 ; 2013 >

  }

  {

      title <
        name = Open Health Data ;
        eissn = 2054-7102
      >

      comment[publisher] = Ubiquity Press
      param[base_url] = https://account.openhealthdata.metajnl.com/
      param[journal_id] = up-j-ohd
      #LXQUEUE-2158
      
      au < ojs3.ClockssOjs3Plugin ; manifest ; 2022 ; 9 ; Open Health Data Volume 9 ; 2022 >

  }

}
