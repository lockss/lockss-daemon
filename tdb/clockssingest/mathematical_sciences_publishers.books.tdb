{

  publisher <
    name = Mathematical Sciences Publishers ;
    info[contract] = 2012 ;
    info[back] = 1997 ;
    info[tester] = 8 ;
    info[poller] = 2
  >


######Books
    plugin = org.lockss.plugin.mathematicalsciencespublishers.ClockssMathematicalSciencesPublishersPlugin
    #param[base_url] = http://msp.org/
    implicit < status ; status2 ; year ; name ; volume ; param[year] ; param[base_url] ; hidden[proxy] >
    
  {
  
    title < 
      name = The Open Book Series ;
      issn = 2329-9061 ;
      eissn = 2329-907X ;
      type = bookSeries 
      >
      
      param[journal_id] = obs
      #See https://msp.org/obs/index.xhtml
      #No volumes for 2021 or 2022.
    
      au < finished ; finished ; 2013 ; The Open Book Series Volume 2013 ; 1 ; 2013 ; http://msp.org/ ; >
      au < finished ; frozen ; 2019 ; The Open Book Series Volume 2019 ; 2 ; 2019 ; https://msp.org/ ; reingest2.clockss.org:8085 >
      au < finished ; frozen ; 2020 ; The Open Book Series Volume 2020 ; 3-4 ; 2020 ; https://msp.org/ ; reingest3.clockss.org:8083 >
      au < finished ; manifest ; 2022 ; The Open Book Series Volume 2022 ; 5 ; 2022 ; https://msp.org/ ; reingest1.clockss.org:8082 >

  }

}
