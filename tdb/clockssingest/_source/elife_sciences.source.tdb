{
  publisher <
    name = eLife Sciences Publications ;
    info[contract] = 2020 ;
    info[tester] = S ;
    info[platform] = Source
  >
  hidden[proxy] = DIRECT

  {
    title <
       name = eLife Sciences Preprint Source Content
    >

    {
      ### HTTPS Journals Format YEAR 
      param[base_url] = https://clockss-ingest.lockss.org/sourcefiles/elifepreprint-released/
      plugin = org.lockss.plugin.clockss.elifesciences.ClockssElifeSciencesSourcePlugin
      implicit < status ; status2 ; year ; name ; param[year] >

      #To be deleted from production machines
      au < zapped ; superseded ; 2025 ; eLife Sciences Preprint Source Content 2025 [superseded] ; 2025 >
      #No more AUs. Moved to directories.
    }
    {
      ### HTTPS Journals Format DIR 
      param[base_url] = https://clockss-ingest.lockss.org/sourcefiles/elifepreprint-released/
      plugin = org.lockss.plugin.clockss.elifesciences.ClockssElifeSciencesJournalsSourcePlugin
      implicit < status ; status2 ; year ; name ; param[directory] >

      au < readySource ; crawling ; 2025 ; eLife Sciences Preprint Source Content 2025_01 ; 2025_01 > #bucket 2025_01 has 7 Preprint zip files in journal format
      #No more AUs. Moved to Preprint format
    }
    {
      ### HTTPS Preprint Format DIR 
      param[base_url] = https://clockss-ingest.lockss.org/sourcefiles/elifepreprint-released/
      plugin = org.lockss.plugin.clockss.elifesciences.ClockssElifeSciencesPreprintSourcePlugin
      implicit < status ; status2 ; year ; name ; param[directory] >

      au < readySource ; crawling ; 2025 ; eLife Sciences Preprint Source Content 2025_02 ; 2025_02 > #bucket 2025_02 has 7609 Preprint zip files in preprint format
      au < readySource ; crawling ; 2026 ; eLife Sciences Preprint Source Content 2026_01 ; 2026_01 >
      au < expected ; exists ; 2027 ; eLife Sciences Preprint Source Content 2027_01 ; 2027_01 >

    }
  }


  {
    title <
       name = eLife Sciences Journals Source Content
    >

    { 
      ### HTTP Journals Format YEAR 
      param[base_url] = http://clockss-ingest.lockss.org/sourcefiles/elife-released/
      plugin = org.lockss.plugin.clockss.elifesciences.ClockssElifeSciencesSourcePlugin
      implicit < status ; status2 ; year ; name ; param[year] >

      au < zapped ; finished ; 2020 ; eLife Sciences Journals Source Content 2020 ; 2020 >
      au < zapped ; finished ; 2021 ; eLife Sciences Journals Source Content 2021 ; 2021 >
      au < readySource ; finished ; 2022 ; eLife Sciences Journals Source Content 2022 ; 2022 >
      #No more AUs. Moved to https.
    }
    {
      ### HTTPS Journals Format YEAR 
      param[base_url] = https://clockss-ingest.lockss.org/sourcefiles/elife-released/
      plugin = org.lockss.plugin.clockss.elifesciences.ClockssElifeSciencesSourcePlugin
      implicit < status ; status2 ; year ; name ; param[year] >

      au < readySource ; finished ; 2023 ; eLife Sciences Journals Source Content 2023 ; 2023 >
      au < readySource ; crawling ; 2024 ; eLife Sciences Journals Source Content 2024 ; 2024 >
      au < readySource ; crawling ; 2025 ; eLife Sciences Journals Source Content 2025 ; 2025 >
      au < readySource ; crawling ; 2026 ; eLife Sciences Journals Source Content 2026 ; 2026 >
      #No more AUs. Moved to directories
    }

    {
      ### HTTPS Journals Format DIR 
      param[base_url] = https://clockss-ingest.lockss.org/sourcefiles/elife-released/
      plugin = org.lockss.plugin.clockss.elifesciences.ClockssElifeSciencesJournalsSourcePlugin
      implicit < status ; status2 ; year ; name ; param[directory] >

      au < expected ; exists ; 2027 ; eLife Sciences Journals Source Content 2027_01 ; 2027_01 >

    }

  }

}
