{

  publisher <
    name = Thong Nhat Hospital ;
    info[contract] = 2026 ;
    info[back] = 2025 ;
    info[tester] = 8 ;
    info[platform] = OJS3
  >

    plugin = org.lockss.plugin.ojs3.ClockssOjs3Plugin
    implicit < status ; status2 ; year ; name ; volume ; param[year] ; hidden[proxy] >
    #OJS3
    attr[start_stem] =
    #attr[start_stem] = index.php/

  {
  
    title < 
      name = Journal of Health and Aging ;
      issn = 3093-3102 ;
      eissn = 3093-3110
    >
      
      #published 2025 to present
      param[base_url] = https://tcsuckhoelaohoa.vn/
    {
      param[journal_id] = bvtn/en

      au < testing ; exists ; 2025 ; Journal of Health and Aging Volume 2025 [English] ; 1 ; 2025 ; >
      au < testing ; exists ; 2026 ; Journal of Health and Aging Volume 2026 [English] ; 2 ; 2026 ; >
    }

    {
      param[journal_id] = bvtn/vi

      au < testing ; exists ; 2025 ; Journal of Health and Aging Volume 2025 [Vietnamese] ; 1 ; 2025 ; >
      au < testing ; exists ; 2026 ; Journal of Health and Aging Volume 2026 [Vietnamese] ; 2 ; 2026 ; >
    }
  }

}
