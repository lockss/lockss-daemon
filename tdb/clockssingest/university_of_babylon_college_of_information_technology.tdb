{

  publisher <
    name = University of Babylon, College of Information Technology ;
    info[contract] = 2008 ;
    info[back] = 2008 ;
    info[tester] = 5 ;
    info[platform] = bepress
  >
    provider = bepress

  {

    title <
      name = Journal of Intelligent Informatics, Networking, and Cybersecurity ;
      eissn = 3106-1192
    >
      #published 2025-present
      implicit < status ; status2 ; year ; name ; param[volume] ; hidden[proxy] >
      plugin = org.lockss.plugin.bepress.ClockssBerkeleyElectronicPressPlugin
      param[base_url] = https://jiinc.uobabylon.edu.iq/
      param[journal_abbr] = journal

      #implicit < status ; status2 ; year ; name ; volume ; param[year] ; hidden[proxy] >

      au < manifest ; exists ; 2025 ; Journal of Intelligent Informatics, Networking, and Cybersecurity Volume 1 ; 1 ; >
      au < manifest ; exists ; 2026 ; Journal of Intelligent Informatics, Networking, and Cybersecurity Volume 2 ; 2 ; >

  }

}
